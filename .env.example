# StudyKing Environment Variables
# Pass these with --dart-define when running or building:
#   flutter run --dart-define=OPENROUTER_API_KEY=sk-...
#   flutter build apk --dart-define=APP_ENV=production

# === API Keys ===
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
WHISPER_API_KEY=

# === Environment ===
# Set to 'production' for release builds, 'development' for debug
APP_ENV=development

# === Version Info ===
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# === Security ===
# Encryption key for local data at rest (must be >= 32 characters)
STUDYKING_ENCRYPTION_KEY=

# === Feature Flags ===
# Set to 'true' to allow unauthenticated mode (debug only)
ALLOW_UNAUTHENTICATED_MODE=false

# === Default Model Overrides ===
# Override default LLM models per provider
# DEFAULT_OPENROUTER_MODEL=gemini-2.0-flash
# DEFAULT_OLLAMA_MODEL=llama3
# DEFAULT_OPENAI_MODEL=gpt-4o-mini
